NODE_ENV=production
PORT=3001
API_PREFIX=/v1

DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/booking_system

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

FRONTEND_URLS=https://your-frontend-domain.example

JWT_SECRET=change-me
JWT_EXPIRES_IN=3600
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_EXPIRES_IN=30d

CSRF_ENABLED=true

UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=/uploads

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=user@example.com
MAIL_PASSWORD=change-me
MAIL_FROM=noreply@example.com
