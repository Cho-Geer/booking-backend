/**
 * 测试环境配置
 * 测试环境使用的环境变量
 * @author Booking System
 * @since 2024
 */

# 应用配置
NODE_ENV=test
PORT=3001

# 数据库配置
DATABASE_URL=postgresql://test:test@localhost:5432/booking_test

# JWT配置
JWT_SECRET=test-jwt-secret-key-for-testing-environment-only
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-refresh-secret-key-for-testing-environment-only
JWT_REFRESH_EXPIRES_IN=7d

# Redis配置（测试环境可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 邮件配置（测试环境使用模拟服务）
MAIL_HOST=smtp.test.com
MAIL_PORT=587
MAIL_USERNAME=test@example.com
MAIL_PASSWORD=test-password
MAIL_FROM=noreply@test.com

# 文件上传配置
UPLOAD_MAX_SIZE=5242880
UPLOAD_DEST=./uploads/test

# 日志配置
LOG_LEVEL=debug
LOG_FILE=./logs/test.log