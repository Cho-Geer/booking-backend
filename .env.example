NODE_ENV=development
PORT=3001
API_PREFIX=/v1

DATABASE_URL=postgresql://postgres:5382@localhost:5432/booking_system

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

FRONTEND_URLS=http://localhost:3000

JWT_SECRET=change-me
JWT_EXPIRES_IN=3600
